SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

YOUTUBE_API_KEY=your-youtube-api-key

BOT_SECRET=your-shared-secret-with-the-telegram-bot
TELEGRAM_BOT_USERNAME=ochiqkurs_bot

# --- AI Tutor (Claude API) ---
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional override; defaults to claude-sonnet-5.
AI_TUTOR_MODEL=

SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# --- SEO / analytics ---
# Canonical origin used for absolute URLs (canonical links, OG images, sitemap).
SITE_URL=https://ochiqkurs.uz
# Google Search Console verification token (the content="..." value).
GOOGLE_SITE_VERIFICATION=
# Google Search Console "HTML file" method: the filename Google gives you,
# e.g. google0123456789abcdef.html (served at the site root).
GOOGLE_VERIFICATION_FILE=
# Cloudflare Web Analytics beacon token.
CLOUDFLARE_ANALYTICS_TOKEN=
